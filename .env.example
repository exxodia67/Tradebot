# Bu dosyayı `.env` olarak kopyala ve değerleri doldur.
# .env dosyası ASLA git'e gönderilmez (.gitignore'da).

# Binance Futures TESTNET anahtarları
# https://testnet.binancefuture.com adresinden ücretsiz alınır (gerçek para YOK).
BINANCE_API_KEY=buraya_testnet_api_key
BINANCE_API_SECRET=buraya_testnet_api_secret

# true = testnet (önerilen, varsayılan). Gerçek paraya geçerken false yapılır.
USE_TESTNET=true

# Telegram botu (opsiyonel): Telegram'da @BotFather -> /newbot -> token buraya
TELEGRAM_BOT_TOKEN=
